# Supabase → Project Settings → API
# https://app.supabase.com/project/_/settings/api
# Use the Sydney (ap-southeast-2) region for AU data residency.
#
# Vercel: set these exact names (Production + Preview), then Redeploy.
# NEXT_PUBLIC_* are embedded at build time — updating keys without redeploy will fail.

NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key
# Legacy alias also accepted by the app if you already set it on Vercel:
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-or-anon-key

# Optional canonical site URL for server-side Auth redirects.
# On the client, window.location.origin is used (localhost / vercel.app / scola.com.au).
# NEXT_PUBLIC_SITE_URL=https://www.scola.com.au

# Service role / secret key: server-side / seed scripts ONLY. Never commit a real value.
# Never expose this to the browser. New format starts with sb_secret_; legacy is a JWT.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Bug-report escalation → GitHub issues (server-side only; never exposed to the client).
# GITHUB_TOKEN: a token with issues:write on the repo. GITHUB_REPO: "owner/repo".
GITHUB_TOKEN=
GITHUB_REPO=owner/repo
